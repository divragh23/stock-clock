# Copy to .env (local dev) or set as the systemd EnvironmentFile (production).

# --- Finnhub (narrow secondary: live-quote fallback + BMO/AMC session flag) ---
# Free key from https://finnhub.io/dashboard. If unset, sessions default to
# "unknown" and there is no live-quote fallback — yfinance + cache still work.
FINNHUB_API_KEY=

# --- Accounts (app-level login) ----------------------------------------------
# Bootstrap admin: created on first startup if the users table is empty. The
# admin can then create/remove other accounts via the app. Leave blank to manage
# accounts entirely by hand.
ADMIN_USERNAME=
ADMIN_PASSWORD=
SESSION_TTL_DAYS=30

# --- Cache --------------------------------------------------------------------
# Stable path for the SQLite file. On the droplet use e.g. /var/lib/stockclock/cache.db
CACHE_PATH=./cache.db

# --- Watch-list & refresh -----------------------------------------------------
TICKERS=NVDA,AAPL,MSFT
STALE_AFTER_HOURS=30
REFRESH_HOUR=22
REFRESH_MINUTE=0
# IANA timezone for the nightly job; empty = server local time.
SCHEDULER_TIMEZONE=
# Warm the cache for TICKERS on startup (background thread; never blocks boot).
REFRESH_ON_START=true

# --- yfinance fetch tuning ----------------------------------------------------
HISTORY_PERIOD=5y
YF_RETRY_ATTEMPTS=3
YF_RETRY_BASE_SECONDS=1.5
BATCH_SLEEP_SECONDS=2.0

# --- CORS (dev only; prod is same-origin behind nginx) ------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
