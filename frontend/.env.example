# Optional. Leave blank for normal use: the app calls "/api/..." on its own
# origin, which the Vite dev proxy (dev) or nginx (prod) forwards to uvicorn.
# Only set this if you want the built bundle to call an absolute API base.
VITE_API_BASE=

# Dev-only: where `vite dev` proxies /api to. Defaults to http://localhost:8000.
VITE_PROXY_TARGET=http://localhost:8000
